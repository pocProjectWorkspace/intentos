{
    "name": "kyc_agent",
    "version": "1.0.0",
    "description": "Classifies, verifies, and cross-checks Indian KYC documents (Aadhaar, PAN, Passport, Voter ID, Driving License)",
    "category": "document",
    "permissions": ["filesystem.read"],
    "optional_permissions": [],
    "actions": ["classify_document", "classify_batch", "extract_kyc_fields", "generate_credit_summary", "check_completeness", "cross_verify"],
    "sandbox_policy": "ReadOnly",
    "platforms": ["linux", "macos", "windows"]
}
