# IntentOS — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file. It is excluded via .gitignore.

# ── Anthropic API ──────────────────────────────────────────
# Your Anthropic API key for Claude inference.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-api-key-here

# ── Model (optional) ──────────────────────────────────────
# Override the default model used by the Intent Kernel.
# Leave commented out to use the default (claude-sonnet-4-20250514).
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
